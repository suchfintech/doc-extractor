# Default vision provider — Qwen via Alibaba DashScope.
DOC_EXTRACTOR_PROVIDER=qwen
DOC_EXTRACTOR_MODEL=qwen-vl-max

# Per-agent provider override examples (uncomment to override the default per doc_type)
# DOC_EXTRACTOR_PROVIDER_PaymentReceipt=anthropic
# DOC_EXTRACTOR_MODEL_PaymentReceipt=claude-sonnet-4-6

# Provider API keys
DASHSCOPE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# AWS — same buckets as merlin
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-2
DOC_SOURCE_BUCKET=golden-mountain-storage
DOC_ANALYSIS_BUCKET=golden-mountain-analysis
